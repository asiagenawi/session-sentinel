{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/src/claude_powernap/usage_check.py\" || python \"${CLAUDE_PLUGIN_ROOT}/src/claude_powernap/usage_check.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/src/claude_powernap/usage_check.py\" || python \"${CLAUDE_PLUGIN_ROOT}/src/claude_powernap/usage_check.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/src/claude_powernap/usage_check.py\" || python \"${CLAUDE_PLUGIN_ROOT}/src/claude_powernap/usage_check.py\""
          }
        ]
      }
    ]
  }
}
